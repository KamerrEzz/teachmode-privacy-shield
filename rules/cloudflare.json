{
  "domain": "dash.cloudflare.com",
  "selectors": [
    "[data-testid='account-id']",
    "[data-testid='zone-id']",
    ".account-id",
    ".zone-id",
    "code",
    "pre",
    "[class*='nameserver']",
    "[class*='ip-address']",
